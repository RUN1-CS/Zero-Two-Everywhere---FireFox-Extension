{
  "description": "A simple extension that adds Zero Two to every image on a youtube.",
  "manifest_version": 3,
  "name": "Zero Two Image Everywhere",
  "version": "1.0",
  "icons": {
    "48": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["zerotwo.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/zero-two-*.png"],
      "matches": ["*://*/*"]
    }
  ]
}
